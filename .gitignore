# ============================================================================
# Top-level .gitignore for the C++ IDE for Android repo.
#
# Layout:
#   spike1/         — research/spike app, kept as historical reference
#   ide/            — the real IDE (clean architecture)
#   termux-pkgs/    — toolchain staging area (downloads + extraction)
# ============================================================================

# ---- Gradle / Android build outputs ----
**/.gradle/
**/build/
**/.idea/
**/*.iml
**/.cxx/
**/captures/
**/.externalNativeBuild/
**/local.properties

# ---- Termux toolchain staging (regenerable from urls) ----
termux-pkgs/*.deb
termux-pkgs/*.gz
termux-pkgs/*.xz
termux-pkgs/closure/
termux-pkgs/*-extract/
termux-pkgs/closure_manifest.json
termux-pkgs/libuser_compiled.so

# ---- Staged Termux toolchain artifacts (run stage_toolchain.py to regenerate)
**/jniLibs/*/libclang.so
**/jniLibs/*/libclangd.so
**/jniLibs/*/libld.so
**/jniLibs/*/libclang-cpp.so
**/jniLibs/*/libLLVM.so
**/jniLibs/*/libc++_shared.so
**/assets/termux.zip

# ---- Build-task outputs (regenerated by Gradle) ----
**/jniLibs/*/libnativehello.so
**/jniLibs/*/libhellolib.so
**/jniLibs/*/libjnibridge.so
**/jniLibs/*/libuser.so
**/jniLibs/*/libdebug_target.so

# ---- IDE / OS noise ----
.DS_Store
Thumbs.db
*.swp
*~
