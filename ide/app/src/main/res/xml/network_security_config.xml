<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config.

  All app traffic goes to the exercises API over HTTPS (Dokploy serves
  a valid Let's Encrypt cert via *.nip.io), so cleartext is disabled
  globally — this satisfies Play Store's network-security review and
  rejects any accidental http:// requests at the platform layer.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
